# ─── ElevenLabs ───────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# The voice ID to use for TTS — clone your character's voice in ElevenLabs dashboard
ELEVENLABS_VOICE_ID=your_cloned_voice_id_here
# ElevenLabs model: flash for low-latency, multilingual-v2 for quality
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5

# ─── Anthropic / Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model to use — Sonnet 4.6 is the recommended default
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Server ───────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,https://your-project.vercel.app

# ─── Safety ───────────────────────────────────────────────────
# Set to "strict" (blocks more), "moderate" (default), or "permissive"
SAFETY_LEVEL=moderate

# ─── Memory ───────────────────────────────────────────────────
# Max conversation turns to keep in active session memory
MEMORY_MAX_TURNS=20
# Max characters retrieved from long-term lore per query
RAG_MAX_CHARS=800
